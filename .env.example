# ============ APP ============
APP_NAME=JobAgent
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-secret
DEBUG=true

# ============ DATABASE ============
DATABASE_URL=postgresql+asyncpg://jobagent:jobagent_dev@postgres:5432/jobagent
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# ============ REDIS ============
REDIS_URL=redis://:redis_dev@redis:6379/0
REDIS_CACHE_TTL=1800

# ============ JWT ============
JWT_PRIVATE_KEY=change-me
JWT_PUBLIC_KEY=change-me
JWT_ACCESS_TOKEN_EXPIRE=900
JWT_REFRESH_TOKEN_EXPIRE=604800

# ============ OAUTH ============
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ============ AI ============
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=gpt-4o-mini
AI_FALLBACK_MODEL=gpt-4o-mini

# ============ STORAGE ============
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=jobagent-uploads
S3_REGION=us-east-1

# ============ EMAIL ============
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@jobagent.local

# ============ MONITORING ============
SENTRY_DSN=

# ============ FRONTEND ============
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
